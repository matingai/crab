{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crab",
  "version": "0.1.4",
  "identifier": "com.matingai.crab.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Crab",
        "width": 1320,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Mating AI",
    "copyright": "Copyright (c) 2026 Mating AI",
    "category": "DeveloperTool",
    "shortDescription": "Local-first agent runtime and desktop shell",
    "longDescription": "Crab is a local-first agent runtime and desktop shell built around a goal-state agent loop, worker delegation, and inspectable tool execution.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
